# ===============================
# SERVER
# ===============================
PORT=3000
NODE_ENV=production

# Refresh automático da página a cada N minutos (5 = padrão; 0 = desativar)
# AUTO_REFRESH_MINUTES=5

# Chave para assinatura de tokens JWT (gerar com: openssl rand -hex 32)
JWT_SECRET=

# ===============================
# SUPABASE (obrigatório)
# ===============================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ===============================
# WHATSAPP PROVIDER
# ===============================
WHATSAPP_PROVIDER=zapi

# URL pública do backend (ex.: https://sua-api.seudominio.com)
APP_URL=

# Origens permitidas no CORS (separadas por vírgula; inclua o frontend)
CORS_ORIGINS=

# Debug do webhook Z-API (logs de payload, DROPPED, eventType, messageId, from, to, chatId, fromMe)
# WHATSAPP_DEBUG=false

# Feature flags (0 ou vazio = desativado; 1 ou true = ativado)
# FEATURE_REGRA_AUTO_WEBHOOK=0
# FEATURE_CAMPANHAS=0
# FEATURE_PROTECAO=1

# ===============================
# Z-API (multi-tenant via empresa_zapi)
# ===============================
# Obrigatórios:
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_WEBHOOK_TOKEN=

# Opcionais (apenas fallback DEV local — NUNCA em produção):
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

# ===============================
# OPENAI (IA do Dashboard) — opcional
# ===============================
# OPENAI_API_KEY=

# ===============================
# META (WhatsApp Cloud API) — opcional
# ===============================
WHATSAPP_TOKEN=
META_ACCESS_TOKEN=
META_APP_SECRET=
PHONE_NUMBER_ID=
WHATSAPP_PHONE_ID=
WEBHOOK_VERIFY_TOKEN=

# ===============================
# CRON / JOBS (opcional)
# ===============================
CRON_SECRET=

# ===============================
# OPERACIONAL - Sync progressiva
# ===============================
# SYNC_BATCH_SIZE=50
# SYNC_INTERVAL_BETWEEN_BATCHES_MS=5000
# SYNC_MAX_PAGES_PER_RUN=20
# SYNC_AUTO_ON_CONNECT=false

# Operacional - Fila
# QUEUE_MAX_CONCURRENT_JOBS=2
# QUEUE_MAX_RETRIES=3
# QUEUE_BACKOFF_BASE_MS=5000

# Operacional - Circuit Breaker Z-API
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_RESET_MS=60000

# Operacional - Modo Seguro
# OPERATIONAL_SAFE_MODE_DEFAULT=true

# Proxy reverso (Nginx/Cloudflare) — use 1 em produção
TRUST_PROXY=1
