# ===============================
# SERVER
# ===============================
# IMPORTANTE: cada variável em uma linha separada (evita NODE_ENV concatenado com a próxima linha)
PORT=3000
NODE_ENV=production

# Chave para assinatura de tokens JWT (gerar com: openssl rand -hex 32)
JWT_SECRET=

# ===============================
# SUPABASE (obrigatório)
# ===============================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ===============================
# WHATSAPP (UltraMsg)
# ===============================
# URL pública do backend (ex.: https://sua-api.seudominio.com)
APP_URL=

# Pasta persistente para mídias (imagens, áudios, PDFs). Os links no banco continuam /uploads/...
# Se vazio, usa ./uploads dentro do projeto — em cada deploy/atualização esse diretório costuma ser recriado
# vazio e as imagens antigas somem. Em Docker/VM: monte um volume e aponte UPLOADS_DIR para ele.
# UPLOADS_DIR=/var/lib/whatsapp-plataforma/uploads

# Token para autenticar webhooks UltraMsg
WHATSAPP_WEBHOOK_TOKEN=
# Fallback por instanceId quando token estiver ausente/inválido (NÃO recomendado em produção)
# Default no código: true em dev, false em produção
# ALLOW_INSTANCEID_WEBHOOK_FALLBACK=0

# Base URL UltraMsg (default: https://api.ultramsg.com). Credenciais por empresa vêm de empresa_zapi.
ULTRAMSG_BASE_URL=https://api.ultramsg.com
# Delay entre envios em ms — evita bloqueio WhatsApp. Recomendado: 1000 (1s) para envios rápidos
# 0 = sem delay. Aplica-se a TODOS os envios (mensagem finalização, chatbot, regras, opt-out).
# ULTRAMSG_SEND_DELAY_MS=1000
# configureWebhooks: sendDelay (s), sendDelayMax (s) — sendDelayMax deve ser >= sendDelay
# ULTRAMSG_SEND_DELAY=1
# ULTRAMSG_SEND_DELAY_MAX=15
# ULTRAMSG_WEBHOOK_RETRIES=3
# ULTRAMSG_WEBHOOK_DOWNLOAD_MEDIA: true por padrão (áudio/imagem chegam com URL). Use false para desativar.
# Em produção: NÃO usados — dados vêm de empresa_zapi. Apenas para dev local sem banco configurado.
# ULTRAMSG_INSTANCE_ID=instance51534
# ULTRAMSG_TOKEN=r6ztawoqwcfhzrd

# Origens permitidas no CORS (separadas por vírgula; inclua o frontend)
CORS_ORIGINS=

# ===============================
# Web Push (PWA / notificações fora do app)
# ===============================
# Gere um par de chaves VAPID (apenas no servidor; nunca commite a privada):
#   cd backend && npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Assunto de contato para o serviço push (formato mailto: ou URL https:)
# VAPID_SUBJECT=mailto:suporte@suaempresa.com.br
# TTL do Web Push em segundos (fallback quando celular está offline/desligado; padrão: 604800 = 7 dias)
# WEB_PUSH_TTL_SECONDS=604800

# Debug do webhook (1 = logs detalhados). Produção: deixe vazio.
# WHATSAPP_DEBUG=0

# Banner "WhatsApp desconectado": oculto por padrão (Z-API removida). Use HIDE_WHATSAPP_DISCONNECT_BANNER=0 para exibir.
# HIDE_WHATSAPP_DISCONNECT_BANNER=0

# Feature flags (0 ou vazio = desativado; 1 ou true = ativado)
# FEATURE_REGRA_AUTO_WEBHOOK=0
# FEATURE_CAMPANHAS=0
# FEATURE_PROTECAO=1

# ===============================
# OPENAI (IA do Dashboard) — opcional
# ===============================
# OPENAI_API_KEY=

# ===============================
# META (WhatsApp Cloud API) — opcional
# ===============================
# WHATSAPP_TOKEN=
# META_ACCESS_TOKEN=
# META_APP_SECRET=
# PHONE_NUMBER_ID=
# WHATSAPP_PHONE_ID=
# WEBHOOK_VERIFY_TOKEN=

# ===============================
# CRM — Google Calendar (OAuth) — opcional
# ===============================
# Criar credenciais "OAuth client ID" (Web) no Google Cloud Console.
# Authorized redirect URI: {APP_URL}/api/crm/google/callback (ex.: https://sua-api.com/api/crm/google/callback)
# CRM_GOOGLE_CLIENT_ID=
# CRM_GOOGLE_CLIENT_SECRET=
# Se vazio, usa redirect {APP_URL}/api/crm/google/callback
# CRM_GOOGLE_REDIRECT_URI=

# ===============================
# CRON / JOBS (opcional)
# ===============================
# Secret para autenticar chamadas de cron (ex: timeout-inatividade). Use header X-Cron-Secret.
# Se vazio, rota POST /jobs/timeout-inatividade retorna 503.
CRON_SECRET=
# Finalização automática por ausência do cliente (job interno no backend).
# Kill switch global: padrão desativado para evitar encerramento acidental em massa.
# 1/true = permite rodar a funcionalidade; 0/false/vazio = bloqueia para todas as empresas.
# ABSENCE_FINALIZATION_GLOBAL_ENABLED=0
# 1/true = habilitado (padrão), 0/false = desabilitado.
# ABSENCE_FINALIZATION_SCHEDULER_ENABLED=1
# Intervalo em minutos (mínimo 1, máximo 60). Padrão: 5.
# ABSENCE_FINALIZATION_INTERVAL_MINUTES=5

# Operacional
# SYNC_BATCH_SIZE=50
# SYNC_INTERVAL_BETWEEN_BATCHES_MS=5000
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_RESET_MS=60000

# Proxy reverso (Nginx/Cloudflare) — use 1 em produção
TRUST_PROXY=1

# ===============================
# SCRIPTS (criar-admin, etc.)
# ===============================
# ADMIN_EMAIL=admin@empresa.com
# ADMIN_SENHA=minhasenha
# ADMIN_NOME=Administrador

# ===============================
# DESENVOLVIMENTO
# ===============================
# Auto-refresh do SPA a cada N minutos (0 = desativado). Default: 5
# AUTO_REFRESH_MINUTES=5

# Timeout em ms para requisições UltraMsg. Default: 30000
# ULTRAMSG_TIMEOUT_MS=30000

# PostgreSQL (opcional; projeto usa Supabase por padrão)
# PG_HOST=localhost
# PG_USER=postgres
# PG_PASSWORD=
# PG_DATABASE=whatsapp
# PG_PORT=5432

# ===============================
# PRODUTOS (PostgreSQL separado)
# ===============================
PRODUTOS_DB_HOST=
PRODUTOS_DB_PORT=5432
PRODUTOS_DB_NAME=zaperp_produtos
PRODUTOS_DB_USER=postgres
PRODUTOS_DB_PASSWORD=
PRODUTOS_DB_SSL=false
# PRODUTOS_DB_POOL_MAX=10
# PRODUTOS_DB_IDLE_TIMEOUT_MS=30000
# PRODUTOS_DB_CONNECTION_TIMEOUT_MS=10000

# ===============================
# PRODUTOS SYNC (SQL Server -> PostgreSQL)
# ===============================
PRODUTOS_SYNC_ENABLED=false
PRODUTOS_SYNC_INTERNAL_ENABLED=false
PRODUTOS_SYNC_INTERVAL_MINUTES=30
# PRODUTOS_SYNC_BATCH_SIZE=500

# Preencha os campos WM_* abaixo apenas se for usar sincronização interna do backend.
# Se você já sincroniza externamente (ETL/serviço separado), pode deixar tudo vazio.
# WM_PRODUTOS_COMPANY_ID=1
# WM_SQLSERVER_HOST=
# WM_SQLSERVER_PORT=1433
# WM_SQLSERVER_DATABASE=
# WM_SQLSERVER_USER=
# WM_SQLSERVER_PASSWORD=
# WM_SQLSERVER_ENCRYPT=false
# WM_SQLSERVER_TRUST_CERT=true
# WM_SQLSERVER_POOL_MAX=5
# WM_SQLSERVER_IDLE_TIMEOUT_MS=30000
# WM_SQLSERVER_CONNECTION_TIMEOUT_MS=10000
# WM_SQLSERVER_REQUEST_TIMEOUT_MS=60000
