# ===============================
# SERVER
# ===============================
# IMPORTANTE: cada variável em uma linha separada (evita NODE_ENV concatenado com a próxima linha)
PORT=3000
NODE_ENV=production

# Chave para assinatura de tokens JWT (gerar com: openssl rand -hex 32)
JWT_SECRET=

# ===============================
# SUPABASE (obrigatório)
# ===============================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ===============================
# WHATSAPP (UltraMsg)
# ===============================
# URL pública do backend (ex.: https://sua-api.seudominio.com)
APP_URL=

# Token para autenticar webhooks UltraMsg
WHATSAPP_WEBHOOK_TOKEN=

# Credenciais padrão (opcional — prioridade: empresa_zapi no banco)
ULTRAMSG_BASE_URL=https://api.ultramsg.com
# Delay entre envios em ms (0 = sem delay, envio imediato)
# ULTRAMSG_SEND_DELAY_MS=0
# configureWebhooks: ULTRAMSG_SEND_DELAY (s), ULTRAMSG_SEND_DELAY_MAX (s), ULTRAMSG_WEBHOOK_DOWNLOAD_MEDIA (true/false)
ULTRAMSG_INSTANCE_ID=instance51534
ULTRAMSG_TOKEN=r6ztawoqwcfhzrd

# Origens permitidas no CORS (separadas por vírgula; inclua o frontend)
CORS_ORIGINS=

# Debug do webhook (1 = logs detalhados). Produção: deixe vazio.
# WHATSAPP_DEBUG=0

# Banner "WhatsApp desconectado": oculto por padrão (Z-API removida). Use HIDE_WHATSAPP_DISCONNECT_BANNER=0 para exibir.
# HIDE_WHATSAPP_DISCONNECT_BANNER=0

# Feature flags (0 ou vazio = desativado; 1 ou true = ativado)
# FEATURE_REGRA_AUTO_WEBHOOK=0
# FEATURE_CAMPANHAS=0
# FEATURE_PROTECAO=1

# ===============================
# OPENAI (IA do Dashboard) — opcional
# ===============================
# OPENAI_API_KEY=

# ===============================
# META (WhatsApp Cloud API) — opcional
# ===============================
# WHATSAPP_TOKEN=
# META_ACCESS_TOKEN=
# META_APP_SECRET=
# PHONE_NUMBER_ID=
# WHATSAPP_PHONE_ID=
# WEBHOOK_VERIFY_TOKEN=

# ===============================
# CRON / JOBS (opcional)
# ===============================
CRON_SECRET=

# Operacional
# SYNC_BATCH_SIZE=50
# SYNC_INTERVAL_BETWEEN_BATCHES_MS=5000
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_RESET_MS=60000

# Proxy reverso (Nginx/Cloudflare) — use 1 em produção
TRUST_PROXY=1
